{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "plugin": [
    "understand-anything@git+https://github.com/Lum1104/Understand-Anything.git",
  ],
  "tools": {
    "skill": true,
  },
  "permission": {
    "skill": { "*": "allow" },
  },
  "default_agent": "orchestrator",
  "mcp": {
    "n8n-web": {
      "type": "remote",
      "url": "http://thor.sealix.eu:5678/mcp/web-searcher",
      "enabled": true,
    },
  },
  "autoupdate": "notify",
  "enabled_providers": ["valmido"],
  "disabled_providers": ["openai", "anthropic", "google", "groq", "mistral"],
  "provider": {
    "valmido": {
      "name": "Valmido (vLLM Local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://thor.sealix.eu:8091/v1",
        "apiKey": "", // Laisser vide si pas d'API key
      },
      "models": {
        "QWEN_3.6_A3B": {
          "name": "qwen3-35b (VLLM)",
          "id": "qwen3-35b",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 64000,
          },
        },
      },
    },
  },
}
